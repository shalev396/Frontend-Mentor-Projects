# GitHub Actions — mirror these in repository/environment configuration (not all belong in a local .env file).
# Repository secrets
AWS_ACCOUNT_ID="YOUR_AWS_ACCOUNT_ID"
# Repository variables
AWS_REGION="YOUR_AWS_REGION"
# Environment secrets
AWS_S3_BUCKET="YOUR_AWS_S3_BUCKET"
AWS_CLOUDFRONT_DISTRIBUTION_ID="YOUR_AWS_CLOUDFRONT_DISTRIBUTION_ID"
# Environment variables
